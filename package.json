{
    "name": "@j7239/elementary-ui",
    "version": "1.0.2",
    "description": "Elementary UI components library",
    "main": "./dist/elementary-ui.umd.js",
    "module": "./dist/elementary-ui.es.js",
    "exports": {
        ".": {
            "import": "./dist/elementary-ui.es.js",
            "require": "./dist/elementary-ui.umd.js"
        }
    },
    "scripts": {
        "build:manifests": "node build.js",
        "build:css": "sass --style compressed --quiet-deps --load-path=node_modules --silence-deprecation=color-functions,global-builtin,import component-assets/scss/main.scss dist/css/styles.min.css",
        "watch:css": "sass --watch --quiet-deps --load-path=node_modules --silence-deprecation=color-functions,global-builtin,import component-assets/scss/main.scss dist/css/styles.min.css",
        "build:lib": "vite build",
        "build": "npm run build:manifests && npm run build:lib",
        "postbuild": "node scripts/sync-pkg.js",
        "init": "node scripts/init.js",
        "new": "node scripts/new-component.js",
        "dev": "npx serve . -l 8000",
        "start": "npx serve . -l 8000"
    },
    "author": "",
    "license": "MIT",
    "files": [
        "dist",
        "component-assets"
    ],
    "dependencies": {
        "@fortawesome/fontawesome-free": "^7.2.0",
        "bootstrap": "^5.3.8"
    },
    "devDependencies": {
        "sass": "^1.99.0",
        "serve": "^14.2.0",
        "vite": "^4.5.14"
    }
}
